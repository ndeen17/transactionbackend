NODE_ENV=development
PORT=4000

MONGODB_URI=mongodb://127.0.0.1:27017/transactionbank

CORS_ORIGIN=http://localhost:5173

# Get a key at https://resend.com — until you verify a sending domain there,
# the sandbox sender below can only deliver to YOUR OWN Resend account email.
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM="Astera Banking <onboarding@resend.dev>"

OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# From your Cloudinary dashboard (cloudinary.com/console). KYC documents are
# uploaded as type "authenticated" — not publicly reachable by a bare URL.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
KYC_MAX_FILE_SIZE_MB=5

BCRYPT_SALT_ROUNDS=12

JWT_SECRET=change_me_dev_secret
JWT_EXPIRES_IN=7d

# Set to true to log generated OTP codes to the server console (dev convenience
# so you can test the verify step without waiting on real email delivery).
DEBUG_LOG_OTP=true
